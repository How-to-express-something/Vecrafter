# 强制所有文本文件在仓库中使用 LF 行尾
* text=auto eol=lf

# Python 文件
*.py text eol=lf

# 配置文件
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# 文档
*.md text eol=lf
*.txt text eol=lf

# 脚本
*.sh text eol=lf

# 二进制文件（不做行尾转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
